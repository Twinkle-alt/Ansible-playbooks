---
 - hosts: "{{ deployment_host}}"
   become: yes
   tasks:
     - name: Download hello.txt
       get_url:
        url: https://github.com/Twinkle-alt/Ansible-playbooks/blob/main/hello.txt
        dest: /home/ubuntu/
     - name: copying the files
       copy:
         src: /home/ubuntu/hello.txt
         dest: /home/ubuntu/twinkle/
         remote_src: yes
     - name: creating empty file
       file:
         path: /home/ubuntu/bye.txt
         state: touch
